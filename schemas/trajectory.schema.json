{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localai.dev/schemas/trajectory.schema.json",
  "title": "Trajectory",
  "description": "One completed task's (context, response, reward) tuple — Loop 4 training feedstock (spec 16 RS12). Captured from Day 1, consumed Phase 9+. SecretFilter-scrubbed at write (RS13).",
  "type": "object",
  "required": [
    "schema_version",
    "trajectory_id",
    "decision_event",
    "route_chain",
    "model_id",
    "context",
    "response",
    "reward"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "trajectory_id": { "type": "string", "description": "content hash of (decision_event, response)" },
    "decision_event": { "type": "integer", "description": "events.id of the OnRoute decision (spec 06 R2)" },
    "route_chain": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["LOCAL", "LOCAL_SELFCHECK", "SEARCH", "COUNCIL_DECIDE", "COUNCIL_FACT", "AGENT"] },
      "description": "escalation chain in order; last entry resolved the task (spec 16 RS8)"
    },
    "model_id": { "type": "string", "description": "e.g. 'gemma4-12b', 'gemma4-e4b', or council provider id" },
    "sampling": {
      "type": "object",
      "properties": {
        "temp": { "type": "number" },
        "seed": { "type": "integer" },
        "k": { "type": "integer", "description": "self-consistency samples if >1" }
      }
    },
    "context": {
      "type": "object",
      "required": ["assembled_prompt", "taint"],
      "properties": {
        "assembled_prompt": { "type": "string", "description": "post-assembly, pre-send; SecretFilter-scrubbed" },
        "taint": {
          "type": "object",
          "required": ["has_untrusted", "provenance_mix"],
          "properties": {
            "has_untrusted": { "type": "boolean", "description": "true → excluded from training export views by default (RS13, G-01)" },
            "provenance_mix": { "type": "number", "minimum": 0, "maximum": 1 },
            "untrusted_chunk_ids": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "response": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": { "type": "string", "description": "SecretFilter-scrubbed" },
        "cost_tokens": { "type": "integer" },
        "latency_ms": { "type": "integer" }
      }
    },
    "reward": {
      "type": "object",
      "required": ["computed", "booked", "durability_outcome"],
      "properties": {
        "computed": { "type": "number", "description": "weighted combine at booking (spec 06 §4)" },
        "booked": { "type": "boolean", "description": "false = hold window still open or unattributed (RS9)" },
        "durability_outcome": {
          "enum": ["survived", "reverted", "reedited", "rejected", "accepted_explicit", "unattributed"],
          "description": "binary-izable outcome — the KTO label (docs/open-questions.md Loop 4)"
        },
        "signal_ids": { "type": "array", "items": { "type": "integer" }, "description": "rewards.id rows backing this" },
        "weights_version": { "type": "integer", "description": "reward-weight config version at booking (RS11)" }
      }
    },
    "task_class": { "enum": ["code", "math", "factual", "judgment", "humanities", "ops"] },
    "verifier": {
      "type": "object",
      "description": "present when an objective verifier ran (RFT view eligibility, spec 06 R8)",
      "properties": {
        "kind": { "enum": ["tests", "compile", "council_factcheck", "citation_resolved"] },
        "passed": { "type": "boolean" }
      }
    },
    "created_seq": { "type": "integer", "description": "events rowid ordering, not wall-clock (G-09)" }
  }
}
